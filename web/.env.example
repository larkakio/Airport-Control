# Canonical site URL for Open Graph (also used as metadataBase). Local dev falls back to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://your-domain.example
NEXT_PUBLIC_CHAIN_ID=8453
NEXT_PUBLIC_CHECK_IN_CONTRACT_ADDRESS=0x4FF7264F93eb28556a1606BDa87c11D7A8f34dF2
NEXT_PUBLIC_BASE_APP_ID=your-base-dev-app-id
NEXT_PUBLIC_BUILDER_CODE=bc_your_builder_code
# Optional: raw ERC-8021 suffix hex (overrides ox generation)
# NEXT_PUBLIC_BUILDER_CODE_SUFFIX=0x
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
